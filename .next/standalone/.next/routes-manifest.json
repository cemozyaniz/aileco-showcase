{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/forest/tree/[public_id]",
      "regex": "^/forest/tree/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPpublic_id": "nxtPpublic_id"
      },
      "namedRegex": "^/forest/tree/(?<nxtPpublic_id>[^/]+?)(?:/)?$"
    },
    {
      "page": "/forest/tree/[public_id]/og-image",
      "regex": "^/forest/tree/([^/]+?)/og\\-image(?:/)?$",
      "routeKeys": {
        "nxtPpublic_id": "nxtPpublic_id"
      },
      "namedRegex": "^/forest/tree/(?<nxtPpublic_id>[^/]+?)/og\\-image(?:/)?$"
    },
    {
      "page": "/smartchain/[id]",
      "regex": "^/smartchain/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/smartchain/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/vcards/[userId]",
      "regex": "^/vcards/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPuserId": "nxtPuserId"
      },
      "namedRegex": "^/vcards/(?<nxtPuserId>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/destek",
      "regex": "^/destek(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/destek(?:/)?$"
    },
    {
      "page": "/favicon.ico",
      "regex": "^/favicon\\.ico(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/favicon\\.ico(?:/)?$"
    },
    {
      "page": "/forest",
      "regex": "^/forest(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/forest(?:/)?$"
    },
    {
      "page": "/gizlilik",
      "regex": "^/gizlilik(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/gizlilik(?:/)?$"
    },
    {
      "page": "/kullanim",
      "regex": "^/kullanim(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/kullanim(?:/)?$"
    },
    {
      "page": "/sifre-sifirlama",
      "regex": "^/sifre\\-sifirlama(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sifre\\-sifirlama(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments",
    "clientParamParsing": false,
    "dynamicRSCPrerender": false
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}